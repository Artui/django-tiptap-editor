{
  "name": "django-tiptap-editor-js",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Embedded TipTap glue + esbuild dual-output build for django-tiptap-editor. Built artifacts are committed under django_tiptap_editor/static/ so consumers stay Python-only.",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@tiptap/core": "2.27.2",
    "@tiptap/starter-kit": "2.27.2",
    "@tiptap/extension-character-count": "2.27.2",
    "@tiptap/extension-color": "2.27.2",
    "@tiptap/extension-font-family": "2.27.2",
    "@tiptap/extension-image": "2.27.2",
    "@tiptap/extension-link": "2.27.2",
    "@tiptap/extension-subscript": "2.27.2",
    "@tiptap/extension-superscript": "2.27.2",
    "@tiptap/extension-table": "2.27.2",
    "@tiptap/extension-table-cell": "2.27.2",
    "@tiptap/extension-table-header": "2.27.2",
    "@tiptap/extension-table-row": "2.27.2",
    "@tiptap/extension-text-align": "2.27.2",
    "@tiptap/extension-text-style": "2.27.2",
    "@tiptap/extension-underline": "2.27.2"
  },
  "devDependencies": {
    "esbuild": "0.28.1",
    "jsdom": "25.0.1",
    "typescript": "5.7.3",
    "vitest": "4.1.9"
  }
}
